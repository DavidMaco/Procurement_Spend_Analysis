{
  "name": "Procurement Intelligence Theme",
  "dataColors": [
    "#0F766E",
    "#2563EB",
    "#D97706",
    "#DC2626",
    "#7C3AED",
    "#14B8A6",
    "#60A5FA",
    "#F59E0B"
  ],
  "background": "#FFFFFF",
  "foreground": "#0F172A",
  "tableAccent": "#2563EB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI",
            "fontSize": 12,
            "color": { "solid": { "color": "#0F172A" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#334155" } },
            "fontSize": 11
          }
        ],
        "background": [
          {
            "show": false,
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ]
      }
    }
  },
  "textClasses": {
    "title": {
      "fontSize": 20,
      "fontFace": "Segoe UI Semibold",
      "color": "#0F172A"
    },
    "header": {
      "fontSize": 14,
      "fontFace": "Segoe UI Semibold",
      "color": "#1E293B"
    },
    "callout": {
      "fontSize": 24,
      "fontFace": "Segoe UI Semibold",
      "color": "#0F766E"
    }
  }
}
